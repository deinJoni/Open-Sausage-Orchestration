# WalletConnect/Reown AppKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Pinata IPFS
PINATA_JWT=

# Porto.sh Smart Wallet Merchant
MERCHANT_ADDRESS=
MERCHANT_PRIVATE_KEY=

# The Graph API
GRAPH_JWT=

# ENS Environment (catmisha or osopit)
# Controls which ENS domain and contract addresses to use
# - catmisha: catmisha.eth (dev/testing)
# - osopit: osopit.eth (production)
# Defaults to "osopit" if not set
NEXT_PUBLIC_ENS_ENVIRONMENT=osopit

# --- Livepeer Studio (live streaming, bring-your-own key) ---
# Server-side API key. Used to create streams and resolve playback info
# (WebRTC + HLS fallback). Get one at:
#   https://livepeer.studio  →  Developers  →  API Keys
LIVEPEER_API_KEY=
# HMAC secret used to verify inbound stream lifecycle webhooks at
# POST /api/webhooks/stream/livepeer. Set the same value in your Livepeer
# Studio webhook configuration.
LIVEPEER_WEBHOOK_SECRET=

# --- Gasless onboarding (both optional) ---
# Layer 1: ERC-7677-compatible paymaster RPC URL.
# When set AND the user's wallet exposes `paymasterService` via EIP-5792
# capabilities, registration is fully gasless via sponsored sendCalls.
# When unset, Layer 1 is disabled and the flow falls through to Layer 2.
# Examples:
#   https://api.pimlico.io/v2/8453/rpc?apikey=YOUR_KEY
#   https://api.developer.coinbase.com/rpc/v1/base/YOUR_KEY
NEXT_PUBLIC_PAYMASTER_URL=

# Layer 2: hex-prefixed 32-byte private key of the relayer EOA.
# When set, /api/relay-register is operational — wallets without paymaster
# capability sign one EIP-191 message and the relayer submits both contract
# calls on their behalf. When unset, Layer 2 is disabled and the flow falls
# through to the original user-paid path.
# Generate via: cast wallet new
RELAYER_PRIVATE_KEY=