# Wallet for deployments and on-chain setup
PRIVATE_KEY=

# Address that should be granted the inviter role on the new registrar
# (used by script/SetupL2Registrar.s.sol)
INVITER_ADDRESS=

# RPC endpoints
BASE_RPC_URL=https://base-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# Used by bash/DeployL2Registrar.sh as the network endpoint to deploy to
L2_RPC_URL=$BASE_RPC_URL

# Etherscan / Basescan API key for contract verification
ETHERSCAN_API_KEY=

# Existing registry to point a new registrar at, and registrar address used by setup/fork scripts
L2_REGISTRY_ADDRESS=
L2_REGISTRAR_ADDRESS=

# Used by scripts/generate-invite.ts (the invite-signing helper)
INVITER_PRIVATE_KEY=
