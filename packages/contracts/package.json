{
  "name": "@osopit/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ENS L2 subname contracts (Durin pattern) for the osopit platform",
  "scripts": {
    "setup": "git submodule update --init --recursive",
    "build": "forge build",
    "test": "forge test",
    "fmt": "forge fmt",
    "clean": "forge clean",
    "deploy:registrar": "bash bash/DeployL2Registrar.sh",
    "setup:registrar": "forge script script/SetupL2Registrar.s.sol --rpc-url $BASE_RPC_URL --broadcast",
    "fork:test": "forge script script/TestFork.s.sol --rpc-url $BASE_RPC_URL",
    "invite:generate": "bun run scripts/generate-invite.ts"
  },
  "dependencies": {
    "viem": "^2.21.54",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1"
  }
}
