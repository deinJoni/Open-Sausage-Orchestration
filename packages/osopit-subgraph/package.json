{
  "name": "osopit-subgraph",
  "license": "UNLICENSED",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "build:catmisha": "graph build subgraph.catmisha.yaml",
    "build:osopit": "graph build subgraph.osopit.yaml",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ osopit-subgraphv-1",
    "deploy:catmisha": "graph deploy --node https://api.studio.thegraph.com/deploy/ catmisha-subgraph subgraph.catmisha.yaml",
    "deploy:osopit": "graph deploy --node https://api.studio.thegraph.com/deploy/ osopit-subgraphv-1 subgraph.osopit.yaml",
    "create-local": "graph create --node http://localhost:8020/ osopit-subgraph",
    "remove-local": "graph remove --node http://localhost:8020/ osopit-subgraph",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 osopit-subgraph",
    "test": "graph test",
    "check-events": "bun run scripts/check-events.ts",
    "check-ownership": "bun run scripts/check-ownership.ts",
    "calculate-namehash": "bun run scripts/calculate-namehash.ts",
    "register-name": "bun run scripts/register-name.ts",
    "emit-test-event": "bun run scripts/emit-text-changed.ts"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.98.1",
    "@graphprotocol/graph-ts": "0.38.2",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "assemblyscript": "0.28.9",
    "matchstick-as": "0.6.0",
    "viem": "^2.38.6"
  }
}
