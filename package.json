{
  "name": "osopit",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "@types/react": "^19.2.2",
      "@types/react-dom": "^19.2.2",
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "scripts": {
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "fix": "turbo run fix",
    "fix:unsafe": "turbo run fix:unsafe",
    "check": "turbo run check",
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @osopit/db db:push",
    "db:studio": "turbo -F @osopit/db db:studio",
    "db:generate": "turbo -F @osopit/db db:generate",
    "db:migrate": "turbo -F @osopit/db db:migrate",
    "db:start": "turbo -F @osopit/db db:start",
    "db:watch": "turbo -F @osopit/db db:watch",
    "db:stop": "turbo -F @osopit/db db:stop",
    "db:down": "turbo -F @osopit/db db:down",
    "setup": "bun install && bun --filter @osopit/contracts setup",
    "contracts:build": "bun --filter @osopit/contracts build",
    "contracts:test": "bun --filter @osopit/contracts test",
    "contracts:deploy:registrar": "bun --filter @osopit/contracts deploy:registrar"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/bun": "^1.3.2",
    "tsdown": "^0.16.4",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "ultracite": "6.3.2"
  },
  "packageManager": "bun@1.3.2",
  "dependencies": {
    "@takumi-rs/image-response": "^0.51.0",
    "cuer": "^0.0.3",
    "nuqs": "^2.7.3",
    "vaul": "^1.1.2"
  }
}
